<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="service.custom.lockdown" name="GE Services Custom Lock" version="1.2.0" provider-name="GE-Home">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.service" library="service.py" start="startup"/>
    <extension point="xbmc.addon.metadata">
        <summary>Multi-User GitHub Controlled Lock System</summary>
        <description>Automatically detects device hostname/MAC and controls access via remote GitHub JSON.</description>
        <platform>all</platform>
    </extension>
</addon>
